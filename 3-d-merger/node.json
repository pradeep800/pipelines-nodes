{
  "version": "1.0",
  "nodeType": "processing",
  "name": "3D Merger",
  "shortDescription": "Merge STL meshes from upstream inputs into a single output file",
  "description": "Downloads STL files from upstream nodes, merges them into a single mesh, and uploads the merged result to S3 as an STL artifact.",
  "hasInput": true,
  "inputDescription": "Input STL files to merge",
  "config": {
    "name": {
      "type": "string",
      "label": "Name",
      "description": "Unique identifier for this merger node in the pipeline",
      "required": true,
      "unique": true,
      "placeholder": "e.g. merge_product_shell",
      "validation": {
        "patternKey": "snake_case"
      }
    }
  },
  "hasOutput": true,
  "outputDescription": "Merged STL output",
  "outputFiles": [
    {
      "name": "result",
      "format": "file",
      "path": "{{artifacts}}/{{pipeline.name}}/{{execution.timestamp}}/{{node.name}}/result.stl"
    }
  ],
  "implementation": {
    "type": "container",
    "entrypoint": "python merge_stl.py",
    "dockerfilePath": "Dockerfile",
    "dockerContext": "3-d-merger"
  }
}