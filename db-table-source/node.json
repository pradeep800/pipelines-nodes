{
  "version": "1.0",
  "nodeType": "processing",
  "name": "DB Table Source",
  "shortDescription": "Fetch a table from the CBR data platform",
  "description": "Authenticates with the CBR Keycloak, downloads a table from your approved access request using the cbr-data-access SDK, and stores the result in MinIO as Parquet for downstream nodes.",
  "githubUrl": "https://github.com/<repo-link>",
  "githubRef": "main",
  "lucideIcon": "DatabaseZap",
  "color": "#6366f1",
  "hasInput": false,
  "config": {
    "name": {
      "type": "string",
      "label": "Node Name",
      "description": "Unique identifier for this node in the pipeline",
      "required": true,
      "unique": true,
      "placeholder": "e.g. fetch_measurement_table",
      "order": 0,
      "validation": {
        "patternKey": "snake_case"
      }
    },
    "username": {
      "type": "string",
      "label": "CBR Username",
      "description": "Your CBR login email (e.g. test@.org)",
      "required": true,
      "unique": false,
      "placeholder": "e.g. test@.org",
      "order": 1
    },
    "password": {
      "type": "string",
      "label": "CBR Password",
      "description": "Your CBR login password",
      "required": true,
      "unique": false,
      "placeholder": "••••••••",
      "order": 2
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Bare table name to download from your approved access request (e.g. person, measurement).",
      "required": true,
      "unique": false,
      "placeholder": "e.g. measurement",
      "order": 3
    }
  },
  "hasOutput": true,
  "outputDescription": "Data fetched from the database table or query as Parquet",
  "outputFiles": [
    {
      "name": "output",
      "format": "parquet",
      "path": "{{artifacts}}/{{pipeline.name}}/{{execution.timestamp}}/{{node.name}}/output.parquet"
    }
  ],
  "implementation": {
    "type": "container",
    "entrypoint": "python fetch.py",
    "dockerfilePath": "Dockerfile",
    "dockerContext": "db-table-source"
  }
}
