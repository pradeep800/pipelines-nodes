{
  "version": "1.0",
  "nodeType": "processing",
  "name": "DB Table Source",
  "shortDescription": "Fetch an OMOP CDM v5.4 table from the CBR data access server",
  "description": "Pick a standard OMOP Common Data Model (v5.4) table and one of your approved access requests. Authenticates as the user who ran the pipeline using the API key injected by Argo (no credentials stored in the pipeline), downloads the table via the cbr-data-access SDK, and stores the result as Parquet for downstream nodes.",
  "githubUrl": "https://github.com/<repo-link>",
  "githubRef": "main",
  "lucideIcon": "DatabaseZap",
  "color": "#6366f1",
  "hasInput": false,
  "config": {
    "name": {
      "type": "string",
      "label": "Node Name",
      "description": "Unique identifier for this node in the pipeline",
      "required": true,
      "unique": true,
      "placeholder": "e.g. fetch_measurement_table",
      "order": 0,
      "validation": {
        "patternKey": "snake_case"
      }
    },
    "omop_table": {
      "type": "select",
      "label": "OMOP Table",
      "description": "OMOP CDM v5.4 table to download. Access is verified against the access request you select below.",
      "required": true,
      "unique": false,
      "placeholder": "",
      "order": 1,
      "options": [
        { "value": "person", "label": "person" },
        { "value": "observation_period", "label": "observation_period" },
        { "value": "visit_occurrence", "label": "visit_occurrence" },
        { "value": "visit_detail", "label": "visit_detail" },
        { "value": "condition_occurrence", "label": "condition_occurrence" },
        { "value": "drug_exposure", "label": "drug_exposure" },
        { "value": "procedure_occurrence", "label": "procedure_occurrence" },
        { "value": "device_exposure", "label": "device_exposure" },
        { "value": "measurement", "label": "measurement" },
        { "value": "observation", "label": "observation" },
        { "value": "death", "label": "death" },
        { "value": "note", "label": "note" },
        { "value": "note_nlp", "label": "note_nlp" },
        { "value": "specimen", "label": "specimen" },
        { "value": "fact_relationship", "label": "fact_relationship" },
        { "value": "location", "label": "location" },
        { "value": "care_site", "label": "care_site" },
        { "value": "provider", "label": "provider" },
        { "value": "payer_plan_period", "label": "payer_plan_period" },
        { "value": "cost", "label": "cost" },
        { "value": "drug_era", "label": "drug_era" },
        { "value": "dose_era", "label": "dose_era" },
        { "value": "condition_era", "label": "condition_era" },
        { "value": "episode", "label": "episode" },
        { "value": "episode_event", "label": "episode_event" },
        { "value": "metadata", "label": "metadata" },
        { "value": "cdm_source", "label": "cdm_source" },
        { "value": "concept", "label": "concept" },
        { "value": "vocabulary", "label": "vocabulary" },
        { "value": "domain", "label": "domain" },
        { "value": "concept_class", "label": "concept_class" },
        { "value": "concept_relationship", "label": "concept_relationship" },
        { "value": "relationship", "label": "relationship" },
        { "value": "concept_synonym", "label": "concept_synonym" },
        { "value": "concept_ancestor", "label": "concept_ancestor" },
        { "value": "source_to_concept_map", "label": "source_to_concept_map" },
        { "value": "drug_strength", "label": "drug_strength" },
        { "value": "cohort", "label": "cohort" },
        { "value": "cohort_definition", "label": "cohort_definition" }
      ]
    },
    "access_request": {
      "type": "access-request",
      "label": "Use Case",
      "description": "Pick one of your approved access requests. Its use case is shown here; the request id is stored and used when the pipeline runs.",
      "required": true,
      "unique": false,
      "placeholder": "Select a use case…",
      "order": 2
    },
    "row_limit": {
      "type": "select",
      "label": "Row Limit",
      "description": "Maximum number of rows to fetch (adds a SQL LIMIT). Choose \"No limit\" to fetch the full table.",
      "required": false,
      "unique": false,
      "options": [
        { "value": "0", "label": "No limit (full table)" },
        { "value": "1000", "label": "1,000 rows" },
        { "value": "10000", "label": "10,000 rows" },
        { "value": "100000", "label": "100,000 rows" },
        { "value": "1000000", "label": "1,000,000 rows" }
      ],
      "order": 3
    }
  },
  "hasOutput": true,
  "outputDescription": "Data fetched from the database table or query as Parquet",
  "outputFiles": [
    {
      "name": "output",
      "format": "parquet",
      "path": "{{artifacts}}/{{pipeline.name}}/{{execution.timestamp}}/{{node.name}}/output.parquet"
    }
  ],
  "implementation": {
    "type": "container",
    "entrypoint": "python transform.py",
    "dockerfilePath": "Dockerfile",
    "dockerContext": "cbr-table-source"
  }
}
