{
  "version": "1.0",
  "nodeType": "processing",
  "name": "DB View Source",
  "shortDescription": "Fetch data from a Keycloak database view",
  "description": "Authenticates with Keycloak using your credentials, then reads a specified view from the Keycloak database and exports the result to S3 as Parquet for downstream nodes.",
  "githubUrl": "https://github.com/<repo-link>",
  "githubRef": "main",
  "lucideIcon": "DatabaseZap",
  "color": "#6366f1",
  "hasInput": false,
  "config": {
    "name": {
      "type": "string",
      "label": "Node Name",
      "description": "Unique identifier for this node in the pipeline",
      "required": true,
      "unique": true,
      "placeholder": "e.g. fetch_users_view",
      "order": 0,
      "validation": {
        "patternKey": "snake_case"
      }
    },
    "username": {
      "type": "string",
      "label": "Keycloak Username",
      "description": "Your Keycloak login username (e.g. admin)",
      "required": true,
      "unique": false,
      "placeholder": "e.g. admin",
      "order": 1
    },
    "password": {
      "type": "string",
      "label": "Keycloak Password",
      "description": "Your Keycloak login password",
      "required": true,
      "unique": false,
      "placeholder": "••••••••",
      "order": 2
    },
    "view_name": {
      "type": "string",
      "label": "View Name",
      "description": "Name of the Keycloak database view or table to read (e.g. public.user_entity)",
      "required": true,
      "unique": false,
      "placeholder": "e.g. public.active_users",
      "order": 3
    }
  },
  "hasOutput": true,
  "outputDescription": "Data fetched from the database view as Parquet",
  "outputFiles": [
    {
      "name": "output",
      "format": "parquet",
      "path": "{{artifacts}}/{{pipeline.name}}/{{execution.timestamp}}/{{node.name}}/output.parquet"
    }
  ],
  "implementation": {
    "type": "container",
    "entrypoint": "python fetch.py",
    "dockerfilePath": "Dockerfile",
    "dockerContext": "db-view-source"
  }
}
