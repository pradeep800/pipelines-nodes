{
  "version": "1.0",
  "nodeType": "processing",
  "name": "DB View Source",
  "shortDescription": "Fetch a view from the CBR data platform",
  "description": "Authenticates with the CBR Keycloak, downloads a specified view from the CBR data-access server using the cbr-data-access SDK, and stores the result in MinIO as Parquet for downstream nodes.",
  "githubUrl": "https://github.com/<repo-link>",
  "githubRef": "main",
  "lucideIcon": "DatabaseZap",
  "color": "#6366f1",
  "hasInput": false,
  "config": {
    "name": {
      "type": "string",
      "label": "Name",
      "description": "Unique identifier for this node in the pipeline",
      "required": true,
      "unique": true,
      "placeholder": "e.g. fetch_users_view",
      "order": 0,
      "validation": {
        "patternKey": "snake_case"
      }
    },
    "username": {
      "type": "string",
      "label": "CBR Username",
      "description": "Your CBR login email (e.g. test@.org)",
      "required": true,
      "unique": false,
      "placeholder": "e.g. test@.org",
      "order": 1
    },
    "password": {
      "type": "string",
      "label": "CBR Password",
      "description": "Your CBR login password",
      "required": true,
      "unique": false,
      "placeholder": "••••••••",
      "order": 2
    },
    "view_name": {
      "type": "string",
      "label": "View Name",
      "description": "Name of the CBR view to fetch (e.g. person, visit_occurrence, cohort_101_data_cost)",
      "required": true,
      "unique": false,
      "placeholder": "e.g. person",
      "order": 3
    }
  },
  "hasOutput": true,
  "outputDescription": "Data fetched from the database view as Parquet",
  "outputFiles": [
    {
      "name": "output",
      "format": "parquet",
      "path": "{{artifacts}}/{{pipeline.name}}/{{execution.timestamp}}/{{node.name}}/output.parquet"
    }
  ],
  "implementation": {
    "type": "container",
    "entrypoint": "python fetch.py",
    "dockerfilePath": "Dockerfile",
    "dockerContext": "db-view-source"
  }
}
